# ---- Secrets & local config ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
# Anchor runtime-secret/cert dirs to the repo root so they never shadow source
# packages (e.g. cli/internal/secrets). Runtime keys live under /var/lib/vulna.
/certificates/
/secrets/

# ---- Python / FastAPI backend ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/

# ---- Node / frontend ----
node_modules/
dash/frontend/dist/
*.tsbuildinfo
.vite/
coverage/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Go / VulnaScout + installer CLI ----
scout/bin/
cli/bin/
*.exe
*.test
*.out
vendor/

# ---- Runtime data / artifacts ----
# Anchored to the repo root so they only match runtime output dirs, not source
# packages such as app/services/reports/.
/data/
/reports/
/evidence/
*.db
*.sqlite
*.sqlite3

# ---- Editor / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
