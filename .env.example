# =============================================================================
# Vulna environment template
# Copy to .env and fill in real values. NEVER commit a populated .env.
# All secrets must be provided via environment or a secrets manager — Vulna
# ships no hard-coded credentials.
# =============================================================================

# ---- General ----
VULNA_ENV=development           # development | production
VULNA_VERSION=latest
LOG_LEVEL=info                  # debug | info | warning | error

# ---- VulnaDash API ----
# Public base URL the frontend and probes use to reach the API.
VULNA_API_BASE_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins for the API.
VULNA_CORS_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vulna
POSTGRES_USER=vulna
# Generate a strong value, e.g.:  openssl rand -base64 32
POSTGRES_PASSWORD=change-me-in-production
# Optional full DSN override (takes precedence over the discrete vars above):
# DATABASE_URL=postgresql+asyncpg://vulna:password@postgres:5432/vulna

# ---- Redis (queue / cache) ----
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379/0

# ---- Application secrets ----
# Master key for encrypting raw scanner evidence at rest. When set, scan
# artifacts are encrypted before they touch the database (a Fernet key is derived
# from this value); when blank, evidence is stored in plaintext (dev only). Set
# and safeguard this in production. Generate with:  openssl rand -base64 32
VULNA_MASTER_KEY=change-me-generate-a-random-32-byte-key
# Secret used to sign session / API tokens. REQUIRED for authentication.
# Generate with:  openssl rand -base64 48
VULNA_SECRET_KEY=change-me-generate-a-random-secret
# Access-token lifetime in minutes (default 720 = 12h).
# VULNA_ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---- Administrator bootstrap ----
# If both are set and no administrator exists yet, a first admin is created on
# startup (and by `vulna bootstrap-admin`). Use a real, deliverable email
# address — special-use TLDs such as .local are rejected. Leave blank to skip.
VULNA_ADMIN_EMAIL=
VULNA_ADMIN_PASSWORD=

# ---- Schema management ----
# When true, the API creates tables from the ORM metadata on startup instead of
# requiring Alembic migrations. Convenient for local/dev; keep FALSE in
# production and run `alembic upgrade head` (or `make backend-migrate`) instead.
VULNA_AUTO_CREATE_TABLES=false
# The API container applies migrations (alembic upgrade head, idempotent) before
# serving. Set false only if you run migrations as a separate step.
# VULNA_RUN_MIGRATIONS=true

# ---- Single-host deployment (docker-compose.single-host.yml) ----
# The single-host overlay sets these for you; they are documented here for
# reference. When enabled, first-run bootstrap also creates a default site and
# auto-enrolls a co-located local Scout (which stays scope-gated). See
# deploy/single-host/README.md and ADR 0017.
# VULNA_BOOTSTRAP_LOCAL_SCOUT=false
# VULNA_LOCAL_SCOUT_TOKEN_TTL_MINUTES=60

# ---- Job & policy signing (Ed25519) ----
# Paths to the Ed25519 keypair used to sign job envelopes and local policies.
# Keys are generated during setup and must be kept secret. Do not commit them.
VULNA_JOB_SIGNING_KEY_PATH=/var/lib/vulna/keys/job_signing_ed25519
VULNA_JOB_SIGNING_PUBKEY_PATH=/var/lib/vulna/keys/job_signing_ed25519.pub

# ---- VulnaScout enrollment / internal CA ----
# Internal CA that signs probe client certificates. Generated on first use if
# missing (or via `vulna ca-init`). Keep the CA private key secret and backed up.
VULNA_CA_KEY_PATH=/var/lib/vulna/keys/ca_key.pem
VULNA_CA_CERT_PATH=/var/lib/vulna/keys/ca_cert.pem
# Issued client-certificate validity (days) and enrollment-token TTL (minutes).
VULNA_CLIENT_CERT_VALIDITY_DAYS=90
VULNA_ENROLLMENT_TOKEN_TTL_MINUTES=15
# A probe is considered offline after this many seconds without a heartbeat.
VULNA_PROBE_OFFLINE_AFTER_SECONDS=180
# Header set by the mTLS-terminating proxy (Caddy) carrying the verified client
# certificate fingerprint. The API must never be exposed directly to probes.
VULNA_PROBE_CERT_FINGERPRINT_HEADER=x-vulna-client-cert-fingerprint

# ---- Storage ----
VULNA_REPORTS_PATH=/var/lib/vulna/reports
# RESERVED / NOT YET USED: filesystem evidence storage arrives with at-rest
# encryption in a later phase; raw output is currently kept in the database.
VULNA_EVIDENCE_PATH=/var/lib/vulna/evidence

# ---- CVE intelligence (VulnaWatch) ----
# Optional NVD API key raises rate limits (https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
EPSS_API_URL=https://api.first.org/data/v1/epss

# ---- Deployment / TLS (production) ----
# Hostname Caddy serves the browser UI on. Leave blank for local/lab mode. A bare
# IP is fine for LAN access (probe mTLS is on its own :8443 listener, so the :443
# UI accepts a no-SNI/raw-IP handshake); public Let's Encrypt mode needs a domain.
VULNA_DOMAIN=
# Set to "internal" for a local self-signed CA, or an email for Let's Encrypt.
CADDY_TLS=internal

# ---- VulnaPulse observability (docker compose --profile monitoring) ----
# Grafana admin password (user "admin"). Change before exposing Grafana.
GRAFANA_PASSWORD=admin
