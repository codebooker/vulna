# =============================================================================
# Vulna environment template
# Copy to .env and fill in real values. NEVER commit a populated .env.
# All secrets must be provided via environment or a secrets manager — Vulna
# ships no hard-coded credentials.
# =============================================================================

# ---- General ----
VULNA_ENV=development           # development | production
VULNA_VERSION=latest
LOG_LEVEL=info                  # debug | info | warning | error

# ---- VulnaDash API ----
# Public base URL the frontend and probes use to reach the API.
VULNA_API_BASE_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins for the API.
VULNA_CORS_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vulna
POSTGRES_USER=vulna
# Generate a strong value, e.g.:  openssl rand -base64 32
POSTGRES_PASSWORD=change-me-in-production
# Optional full DSN override (takes precedence over the discrete vars above):
# DATABASE_URL=postgresql+asyncpg://vulna:password@postgres:5432/vulna

# ---- Redis (queue / cache) ----
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://redis:6379/0

# ---- Application secrets ----
# Master key used to encrypt evidence and stored credentials at rest.
# Generate with:  openssl rand -base64 32
VULNA_MASTER_KEY=change-me-generate-a-random-32-byte-key
# Secret used to sign session / API tokens.
# Generate with:  openssl rand -base64 48
VULNA_SECRET_KEY=change-me-generate-a-random-secret

# ---- Job & policy signing (Ed25519) ----
# Paths to the Ed25519 keypair used to sign job envelopes and local policies.
# Keys are generated during setup and must be kept secret. Do not commit them.
VULNA_JOB_SIGNING_KEY_PATH=/var/lib/vulna/keys/job_signing_ed25519
VULNA_JOB_SIGNING_PUBKEY_PATH=/var/lib/vulna/keys/job_signing_ed25519.pub

# ---- Storage ----
VULNA_REPORTS_PATH=/var/lib/vulna/reports
VULNA_EVIDENCE_PATH=/var/lib/vulna/evidence

# ---- CVE intelligence (VulnaWatch) ----
# Optional NVD API key raises rate limits (https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
EPSS_API_URL=https://api.first.org/data/v1/epss

# ---- Deployment / TLS (production) ----
# Domain Caddy will request a certificate for. Leave blank for HTTP-only lab mode.
VULNA_DOMAIN=
# Set to "internal" for a local self-signed CA, or an email for Let's Encrypt.
CADDY_TLS=internal
