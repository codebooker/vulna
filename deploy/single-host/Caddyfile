# Caddy reverse proxy for the single-host Vulna deployment (Phase 17).
#
# Unlike the base deploy/Caddyfile (which leaves mTLS commented out for the
# operator to enable), this file ships probe mutual-TLS ENABLED, because the
# single-host profile runs a co-located "local Scout" that must authenticate
# exactly like any remote VulnaScout — same security boundary (see ADR 0017 and
# app/api/probe_auth.py).
#
# Listener split (Phase 17 fix): probe mTLS lives on its OWN listener (:8443),
# NOT on the :443 the browser uses. Enabling client_auth on a listener makes
# Caddy require SNI on it, and a browser (or curl) reaching the box by raw IP
# sends no SNI — so sharing :443 broke IP access entirely. With the browser UI on
# a plain :443 (no client_auth) and all probe mTLS on :8443, the dashboard is
# reachable by hostname AND by raw IP, while probes still get a verified client
# certificate.
#
#   :443   {$VULNA_DOMAIN}          — operator browser UI + JWT API (no mTLS)
#   :8443  {$VULNA_DOMAIN}          — remote VulnaScout mTLS (growth to N scouts)
#   :8443  https://vulna-dash       — a stable internal name (Docker alias) the
#                                     co-located local Scout pins mTLS against
#
# client_auth mode is "verify_if_given", NOT "require_and_verify": enrollment
# (POST /api/v1/probes/enroll) is certless by design — a fresh probe has no
# certificate yet — so requiring a client cert at the TLS layer would make
# enrollment impossible. verify_if_given still *verifies* any presented
# certificate against the internal CA (a rogue or self-signed cert is rejected
# at the handshake), and heartbeat/poll endpoints reject a certless request at
# the application layer because no fingerprint header is set. Do NOT use "request"
# — it does not verify at all.
{
	email {$CADDY_TLS}
	# TLS clients do not send SNI for an IP-literal URL. Select the configured
	# appliance certificate in that case so LAN/raw-IP installs remain usable.
	default_sni {$VULNA_DOMAIN:localhost}
	servers :8443 {
		# Caddy automatically enables strict SNI/Host matching with client auth,
		# but Go intentionally sends no SNI for an IP-literal server URL. Both
		# sites on this dedicated listener use the identical verified-client-cert
		# policy, and the API still authenticates every protected probe route, so
		# accepting the raw-IP Host cannot front an unprotected TLS policy.
		strict_sni_host insecure_off
	}
}

# Shared routing to the API/SPA. Two variants differ ONLY in how the probe
# client-certificate fingerprint header is handled.

# Browser/JWT variant (no mTLS): STRIP any inbound fingerprint header so a browser
# can never spoof a probe identity. Operators authenticate with a JWT, not a cert.
(vulna_site_browser) {
	@api path /api/* /health
	handle @api {
		reverse_proxy vulna-api-proxy:8000 {
			header_up -X-Vulna-Client-Cert-Fingerprint
		}
	}
	handle {
		reverse_proxy vulna-frontend-proxy:8080
	}
	encode gzip
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}
}

# mTLS variant: overwrite any client-supplied value with the fingerprint of the
# certificate Caddy verified. For a certless request (enrollment) the placeholder
# is empty, which the API treats as "no probe identity". A lone "set" both injects
# the verified value and defeats spoofing; do NOT add a matching "-delete".
(vulna_site_mtls) {
	@api path /api/* /health
	handle @api {
		reverse_proxy vulna-api-proxy:8000 {
			header_up X-Vulna-Client-Cert-Fingerprint {http.request.tls.client.fingerprint}
		}
	}
	handle {
		reverse_proxy vulna-frontend-proxy:8080
	}
	encode gzip
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}
}

# Operator-facing browser site on :443 — NO client_auth, so the dashboard is
# reachable by hostname or by raw IP (a no-SNI handshake is accepted). Probes
# never use this listener.
{$VULNA_DOMAIN:localhost} {
	import vulna_site_browser
	tls {$CADDY_TLS}
}

# Remote VulnaScout mTLS on :8443 (single-host growth to multiple Scouts). Same
# managed cert as :443, plus client-certificate verification against the CA.
{$VULNA_DOMAIN:localhost}:8443 {
	import vulna_site_mtls
	tls {$CADDY_TLS} {
		client_auth {
			mode verify_if_given
			trust_pool file /etc/caddy/keys/ca_cert.pem
		}
	}
}

# Internal name for the co-located local Scout on :8443. Always the internal CA
# (this name is never public), with the same probe mTLS trust.
https://vulna-dash:8443 {
	import vulna_site_mtls
	tls internal {
		client_auth {
			mode verify_if_given
			trust_pool file /etc/caddy/keys/ca_cert.pem
		}
	}
}
