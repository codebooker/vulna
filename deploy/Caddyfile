# Caddy reverse proxy for VulnaDash.
#
# Behavior is controlled by two environment variables (see .env.example):
#   VULNA_DOMAIN  — the public hostname (blank => HTTP-only local lab mode)
#   CADDY_TLS     — "internal" for a local self-signed CA, or an email for
#                   automatic Let's Encrypt certificates in production.
#
# Routes:
#   /api/*, /health                        -> api:8000
#   everything else                        -> frontend:8080 (SPA)
{
	# Use an internal CA by default; override with a real email for public TLS.
	email {$CADDY_TLS}
}

{$VULNA_DOMAIN:localhost} {
	# --- Probe mutual TLS (enable in production) ---
	# VulnaScout probes authenticate with a client certificate issued by the
	# internal CA. Terminate mTLS here and forward the verified fingerprint to
	# the API. Mount the CA cert (VULNA_CA_CERT_PATH) into the Caddy container.
	#
	# Validated live against Caddy v2.11: the placeholder
	# {http.request.tls.client.fingerprint} is the lowercase-hex SHA-256 of the
	# client-certificate DER, which is exactly the fingerprint the API stores per
	# probe (app/services/ca.py::certificate_fingerprint). See ADR 0003.
	#
	#   tls {$CADDY_TLS} {
	#       client_auth {
	#           # require_and_verify rejects a client with no certificate or a
	#           # certificate not issued by the trust pool, at the TLS layer. Do
	#           # NOT use "request": it neither requires nor verifies the client
	#           # certificate, so an unauthenticated or rogue-CA client would be
	#           # proxied through (verified live).
	#           mode require_and_verify
	#           trust_pool file /etc/caddy/vulna-ca.pem
	#       }
	#   }

	# API and liveness to the backend.
	@api path /api/* /health
	handle @api {
		reverse_proxy vulna-api-proxy:8000 {
			# The API trusts this header only from the proxy, so a client must
			# never be able to set it. Without mTLS (local/dev), strip any inbound
			# value:
			header_up -X-Vulna-Client-Cert-Fingerprint
			# In production, REPLACE the line above with the line below — do not
			# keep both. A delete + set together drops the header entirely (Caddy
			# applies the delete last), which would 401 every probe (verified
			# live). A lone "set" already overwrites any client-supplied value, so
			# it both injects the verified fingerprint and defeats spoofing:
			# header_up X-Vulna-Client-Cert-Fingerprint {http.request.tls.client.fingerprint}
		}
	}

	# Everything else to the frontend SPA.
	handle {
		reverse_proxy vulna-frontend-proxy:8080
	}

	encode gzip

	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}
}
