{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulna.dev/schemas/data-map.json",
  "title": "Vulna Data Map",
  "description": "Machine-readable map of what data Vulna stores, where, its sensitivity, and whether it can leave the deployment (updated through the Phase 44 CSV importer). Not a JSON Schema for validation; a documented data inventory.",
  "version": "6",
  "leaves_deployment": {
    "intelligence_feeds": {
      "destinations": ["services.nvd.nist.gov", "www.cisa.gov", "epss.cyentia.com"],
      "direction": "outbound_download",
      "contains_org_data": false,
      "toggle": "intelligence_feeds_enabled"
    },
    "smtp": {
      "destinations": ["operator-configured"],
      "direction": "outbound",
      "contains_org_data": "selected_notification_fields",
      "toggle": "per_channel"
    },
    "webhooks": {
      "destinations": ["operator-configured"],
      "direction": "outbound",
      "contains_org_data": "selected_notification_fields",
      "toggle": "per_channel"
    },
    "identity_provider": {
      "destinations": ["operator-configured OIDC or SAML provider"],
      "direction": "outbound_and_browser_redirect",
      "contains_org_data": "identity protocol messages only",
      "toggle": "per_provider",
      "default": "off"
    },
    "ticketing": {
      "destinations": ["operator-configured ticket provider"],
      "direction": "outbound",
      "contains_org_data": "selected finding fields only; never evidence or raw scanner output",
      "toggle": "per_connector",
      "default": "off_until_tested"
    },
    "passive_inventory": {
      "destinations": ["operator-configured inventory source"],
      "direction": "outbound_read_only",
      "contains_org_data": "bounded asset observations",
      "toggle": "per_connector",
      "default": "off_until_tested"
    },
    "telemetry": {
      "destinations": ["operator-configured, none by default"],
      "direction": "outbound",
      "contains_org_data": "aggregate_counts_only",
      "toggle": "telemetry_enabled",
      "default": "off",
      "never_contains": [
        "ip_addresses", "hostnames", "usernames", "findings", "cves",
        "evidence", "credentials", "report_contents", "install_identifier"
      ]
    },
    "updates": {
      "destinations": [],
      "direction": "none",
      "note": "The application never contacts a release server; updates are CLI-run."
    }
  },
  "stored_locally": [
    { "category": "organization/sites/scopes", "store": "database", "sensitivity": "low", "in_export": true },
    { "category": "experience profile and onboarding plan", "store": "database", "sensitivity": "low", "in_export": "profile_only" },
    { "category": "scouts", "store": "database", "sensitivity": "low", "in_export": "metadata_only" },
    { "category": "assets/services", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "structured asset context, normalized tags/groups, membership explanations, and ownership history", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "findings", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "risk profiles, immutable score inputs/contributions, remediation units/suggestions, and bounded finding decisions", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "SLA policies, immutable deadline calculations, exceptions, history, and structured guidance", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "raw scanner output", "store": "database", "sensitivity": "medium", "in_export": false },
    { "category": "evidence", "store": "reports volume", "sensitivity": "high", "in_export": false },
    { "category": "reports (files)", "store": "reports volume", "sensitivity": "medium", "in_export": "metadata_only" },
    { "category": "audit log", "store": "database", "sensitivity": "medium", "in_export": false },
    { "category": "user lifecycle and site access metadata", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "password/invitation/reset/recovery material", "store": "database (hashed)", "sensitivity": "critical", "in_export": false },
    { "category": "session device/IP metadata", "store": "database", "sensitivity": "high", "in_export": false },
    { "category": "refresh-token hashes", "store": "database (hashed)", "sensitivity": "critical", "in_export": false },
    { "category": "TOTP seeds", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "MFA recovery codes", "store": "database (one Argon2 hash per code)", "sensitivity": "critical", "in_export": false },
    { "category": "WebAuthn public credentials and short-lived challenges", "store": "database", "sensitivity": "high", "in_export": false },
    { "category": "authentication throttle state", "store": "database (hashed account/IP keys)", "sensitivity": "high", "in_export": false },
    { "category": "identity provider configuration and external subject links", "store": "database", "sensitivity": "high", "in_export": false },
    { "category": "OIDC client secrets and SAML certificates/private keys", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "OIDC/SAML state, nonce, request, and replay records", "store": "database (hashed/encrypted where secret)", "sensitivity": "high", "in_export": false },
    { "category": "SCIM user/group/mapping metadata and sanitized history", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "SCIM bearer tokens and request counters", "store": "database (hashed token)", "sensitivity": "critical", "in_export": false },
    { "category": "authorization roles, permission mappings, scoped grants, and service-account metadata", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "background task payloads, leases, results, errors, and worker heartbeats", "store": "database", "sensitivity": "medium", "in_export": false },
    { "category": "personal/service API-token values and hashes", "store": "value shown once / hash in database", "sensitivity": "critical", "in_export": false },
    { "category": "API-token lifecycle metadata", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "credential vault metadata, assignments, sanitized tests, and usage", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "credential secret versions", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "Scout credential-encryption private key", "store": "Scout state (0600)", "sensitivity": "critical", "in_export": false },
    { "category": "signed Scout credential envelopes", "store": "database (Scout-bound ciphertext)", "sensitivity": "critical", "in_export": false },
    { "category": "software inventory, history, and EOL overrides", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "ticket connector metadata and synchronization history", "store": "database", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "ticket connector secrets", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "passive connector metadata, observations, source links, lifecycle, reconciliation snapshots, and aggregate history", "store": "database", "sensitivity": "high", "in_export": "metadata_and_observations" },
    { "category": "passive inventory connector secrets", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "CSV inventory source uploads", "store": "database (purpose-bound encrypted)", "sensitivity": "high", "in_export": "metadata_only" },
    { "category": "report templates, schedules, and comparison history", "store": "database", "sensitivity": "medium", "in_export": true },
    { "category": "report export passwords", "store": "database (purpose-bound encrypted)", "sensitivity": "critical", "in_export": false },
    { "category": "scope-specific analytics cache", "store": "database", "sensitivity": "medium", "in_export": false },
    { "category": "internal CA + signing keys", "store": "keys volume", "sensitivity": "critical", "in_export": false },
    { "category": "notification/SMTP secrets", "store": "database (encrypted)", "sensitivity": "high", "in_export": false }
  ]
}
