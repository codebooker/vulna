{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulna.dev/schemas/policy.schema.json",
  "title": "Vulna Local Probe Policy",
  "description": "Signed local policy stored on a VulnaScout. The probe enforces this policy independently and rejects any job that violates it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_version",
    "probe_id",
    "site_id",
    "approved_cidrs",
    "denied_cidrs",
    "allow_public_addresses",
    "allowed_modes",
    "allowed_plugins",
    "limits",
    "signature"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "policy_version": { "type": "integer", "minimum": 0 },
    "probe_id": { "type": "string", "format": "uuid" },
    "site_id": { "type": "string", "format": "uuid" },
    "approved_cidrs": {
      "type": "array",
      "items": { "type": "string", "description": "Approved CIDR (IPv4 or IPv6)" }
    },
    "denied_cidrs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allow_public_addresses": {
      "type": "boolean",
      "default": false,
      "description": "Whether public IP ranges may be assessed. Denied by default."
    },
    "allowed_modes": {
      "type": "array",
      "items": { "type": "string", "enum": ["vulnerability_assessment", "controlled_pentest", "full_spectrum"] }
    },
    "allowed_plugins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_web_domains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_hosts", "max_parallel_hosts", "max_packets_per_second", "max_duration_seconds"],
      "properties": {
        "max_hosts": { "type": "integer", "minimum": 1 },
        "max_parallel_hosts": { "type": "integer", "minimum": 1 },
        "max_packets_per_second": { "type": "integer", "minimum": 1 },
        "max_duration_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "credentialed_scans_allowed": { "type": "boolean", "default": false },
    "active_web_scans_allowed": {
      "type": "boolean",
      "default": false,
      "description": "Signed per-Scout opt-in required for ZAP limited-active profiles."
    },
    "exploit_validation_allowed": { "type": "boolean", "default": false },
    "signature": { "type": "string", "description": "Base64 Ed25519 signature over the canonical policy" }
  }
}
