{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulna.dev/schemas/result.schema.json",
  "title": "Vulna Result Upload Envelope",
  "description": "Versioned result envelope uploaded by VulnaScout. Authentication is provided by mTLS; the envelope binds the payload to the job, Scout, signed workflow stage, and scanner. Idempotency-Key remains an HTTP header derived from the decoded payload.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "probe_id",
    "stage",
    "scanner",
    "complete",
    "content_hash",
    "payload_encoding",
    "result_format",
    "byte_length",
    "payload"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "job_id": { "type": "string", "format": "uuid" },
    "probe_id": { "type": "string", "format": "uuid" },
    "stage": { "type": "string", "minLength": 1, "maxLength": 64 },
    "scanner": { "type": "string", "minLength": 1, "maxLength": 64 },
    "complete": { "type": "boolean" },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "SHA-256 of the decoded payload"
    },
    "payload_encoding": { "type": "string", "const": "base64" },
    "result_format": {
      "type": "string",
      "enum": [
        "nmap_xml",
        "nuclei_jsonl",
        "testssl_json",
        "zap_json",
        "metasploit_json",
        "software_inventory_json"
      ]
    },
    "byte_length": { "type": "integer", "minimum": 0, "maximum": 26214400 },
    "payload": { "type": "string", "contentEncoding": "base64" }
  }
}
