{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulna.dev/schemas/export-bundle.schema.json",
  "title": "Vulna Data Export Bundle",
  "description": "Versioned, checksummed export of an organization's non-secret data. Contains no credential values or hashes, keys, certificates, passwords, or report file bytes. Can be validated independently: recompute sha256 over the canonical JSON of every field except 'checksum'.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "exported_at",
    "organization",
    "users",
    "user_site_assignments",
    "authorization_roles",
    "scoped_grants",
    "service_accounts",
    "api_tokens",
    "scim_groups",
    "scim_group_members",
    "scim_group_site_mappings",
    "scim_provisioning_logs",
    "sites",
    "network_scopes",
    "scouts",
    "assets",
    "asset_tags",
    "asset_tag_assignments",
    "asset_groups",
    "asset_group_memberships",
    "department_owners",
    "asset_ownership_history",
    "services",
    "findings",
    "reports",
    "risk_acceptances",
    "finding_notes",
    "checksum"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "4" },
    "exported_at": { "type": "string" },
    "checksum": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "organization": {
      "type": "object",
      "required": ["id", "name", "slug"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "default_timezone": { "type": "string" },
        "experience_profile": {
          "type": "string",
          "enum": ["small_business", "enterprise", "custom"]
        },
        "feature_overrides": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "users": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "email", "role", "account_status", "authentication_source", "site_access_mode"],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "full_name": { "type": ["string", "null"] },
          "role": { "type": "string" },
          "account_status": { "type": "string" },
          "authentication_source": { "type": "string" },
          "scim_external_id": { "type": ["string", "null"] },
          "site_access_mode": { "type": "string" },
          "last_login_at": { "type": ["string", "null"] }
        }
      }
    },
    "user_site_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["user_id", "site_id"],
        "properties": {
          "user_id": { "type": "string" },
          "site_id": { "type": "string" }
        }
      }
    },
    "authorization_roles": { "type": "array", "items": { "type": "object" } },
    "scoped_grants": { "type": "array", "items": { "type": "object" } },
    "service_accounts": { "type": "array", "items": { "type": "object" } },
    "api_tokens": { "type": "array", "items": { "type": "object" } },
    "scim_groups": { "type": "array", "items": { "type": "object" } },
    "scim_group_members": { "type": "array", "items": { "type": "object" } },
    "scim_group_site_mappings": { "type": "array", "items": { "type": "object" } },
    "scim_provisioning_logs": { "type": "array", "items": { "type": "object" } },
    "sites": { "type": "array", "items": { "type": "object" } },
    "network_scopes": { "type": "array", "items": { "type": "object" } },
    "scouts": { "type": "array", "items": { "type": "object" } },
    "assets": { "type": "array", "items": { "type": "object" } },
    "asset_tags": { "type": "array", "items": { "type": "object" } },
    "asset_tag_assignments": { "type": "array", "items": { "type": "object" } },
    "asset_groups": { "type": "array", "items": { "type": "object" } },
    "asset_group_memberships": { "type": "array", "items": { "type": "object" } },
    "department_owners": { "type": "array", "items": { "type": "object" } },
    "asset_ownership_history": { "type": "array", "items": { "type": "object" } },
    "services": { "type": "array", "items": { "type": "object" } },
    "findings": { "type": "array", "items": { "type": "object" } },
    "reports": { "type": "array", "items": { "type": "object" } },
    "risk_acceptances": { "type": "array", "items": { "type": "object" } },
    "finding_notes": { "type": "array", "items": { "type": "object" } }
  }
}
